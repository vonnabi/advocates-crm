# Copy this file to `.env` in the same folder and fill in real values.
# The real `.env` is gitignored — never commit secrets.

# ── Django ──────────────────────────────────────────────
# A long random string. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=advokatcrm.com,www.advokatcrm.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://advokatcrm.com,https://www.advokatcrm.com
# Caddy already redirects http→https; keep this false to avoid a redirect loop.
DJANGO_SECURE_SSL_REDIRECT=false
# Require login for the API (no anonymous access) in production.
CRM_REQUIRE_AUTH=true
# Public URL of the CRM — used to build ONLYOFFICE file/callback URLs.
CRM_PUBLIC_URL=https://advokatcrm.com

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_DB=advokat_crm
POSTGRES_USER=advokat
POSTGRES_PASSWORD=change-me-strong-db-password

# ── ONLYOFFICE (self-hosted Document Server) ────────────
ONLYOFFICE_DOCUMENT_SERVER_URL=https://office.advokatcrm.com
# Must match the JWT secret the Document Server container uses. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(24))"
ONLYOFFICE_JWT_SECRET=change-me-onlyoffice-jwt-secret

# ── AI помічники (real Claude integration) ──────────────
# Anthropic API key. Get one at https://console.anthropic.com → API Keys.
# Leave blank to keep the AI помічники module disabled (it shows a clear
# "not configured" message instead of calling the model). Billed per request.
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-opus-4-8).
# ANTHROPIC_MODEL=claude-opus-4-8
